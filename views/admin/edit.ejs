<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<title><%= title %></title>
<link rel="stylesheet" href="/style.css">
</head>

<body>

<h1>Edit Article</h1>

<form action="/admin/edit/<%= filename %>" method="POST">

<label>Title</label><br>
<input 
type="text" 
name="title" 
value="<%= article.title %>" 
required
>

<br><br>

<label>Date</label><br>
<input 
type="date" 
name="date" 
value="<%= article.date %>" 
required
>

<br><br>

<label>Content</label><br>
<textarea 
name="content" 
rows="10" 
cols="60"
required
><%= article.content %></textarea>

<br><br>

<button type="submit">Update Article</button>

</form>

<br>

<a href="/admin/dashboard">Back to Dashboard</a>

</body>
</html>